# Climbing Wall App Environment Configuration
# Save this file as ".env" inside the "backend" directory

# -----------------------------------
# Super Admin Setup (Runs on first boot)
# -----------------------------------
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change_this_password

# -----------------------------------
# Security & Authentication
# -----------------------------------
# Generate a secure string (e.g. `openssl rand -hex 32` via command line)
SECRET_KEY=
ALGORITHM=HS256
# Token expiration in minutes (43200 = 30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# -----------------------------------
# Database
# -----------------------------------
# The SQLite database path (already mapped correctly in docker-compose.yml)
DATABASE_URL=sqlite:////app/data/climbing_wall.db
# Directory where route photos are uploaded to
PHOTO_DIR=/app/photos

# -----------------------------------
# Frontend & CORS
# -----------------------------------
# A comma-separated list of URLs the backend is allowed to accept requests from.
FRONTEND_URL=http://climb.local:5173,http://localhost:5173,http://localhost:80,http://frontend:80
